# ═══════════════════════════════════════════════
# SMTP — отправка отчётов и уведомлений helpdesk
# ═══════════════════════════════════════════════
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@yandex.ru
SMTP_PASS=your_app_password

# Куда отправлять отчёт по группе "Европласт" (можно несколько через запятую)
REPORT_TO_EVROPLAST=evroplast@yourdomain.com,manager@yourdomain.com

# Куда отправлять отчёт по группе "Онлайн" (можно несколько через запятую)
REPORT_TO_ONLINE=online-client@yourdomain.com

# Fallback-адрес: используется, если не задан group-specific (REPORT_TO_*)
REPORT_TO=admin@yourdomain.com

# Куда отправлять письма helpdesk (несколько через запятую)
HELPDESK_TO=helpdesk@yourdomain.com

# ═══════════════════════════════════════════════
# TRASSIR Производство — SDK HTTP API
# ═══════════════════════════════════════════════
TRASSIR_USER=Admin
TRASSIR_PASS=your_password

# ═══════════════════════════════════════════════
# HiWatch Склад — ISAPI
# ═══════════════════════════════════════════════
HIWATCH_SKLAD_URL=
HIWATCH_SKLAD_USER=
HIWATCH_SKLAD_PASS=your_password

# ═══════════════════════════════════════════════
# HiWatch Цех выдува — ISAPI
# ═══════════════════════════════════════════════
HIWATCH_VYDUV_URL=
HIWATCH_VYDUV_USER=
HIWATCH_VYDUV_PASS=your_password

# ═══════════════════════════════════════════════
# Европласт Стройка — SMB-записи
# ═══════════════════════════════════════════════
STROYKA_SMB_USER=your_smb_user
STROYKA_SMB_PASS=your_smb_password

# ═══════════════════════════════════════════════
# BEWARD (удалённые) — SMB-записи
# ═══════════════════════════════════════════════
BEWARD_SMB_USER=your_smb_user
BEWARD_SMB_PASS=your_smb_password

# ═══════════════════════════════════════════════
# iVMS (Hikvision удалённые) — ISAPI per camera
# ═══════════════════════════════════════════════
IVMS_AERO_USER=
IVMS_AERO_PASS=your_password
IVMS_T2_USER=
IVMS_T2_PASS=your_password
IVMS_MEGAFON_USER=
IVMS_MEGAFON_PASS=your_password

# ═══════════════════════════════════════════════
# Ростелеком — портал lk-b2b.camera.rt.ru
# ═══════════════════════════════════════════════
RT_PORTAL_URL=
RT_PORTAL_USER=your_login
RT_PORTAL_PASS=your_password

# ═══════════════════════════════════════════════
# TP-Link Tapo (Wi-Fi камеры) — RTSP через Camera Account
# ═══════════════════════════════════════════════
# Camera Account = логин/пароль, создаваемые в мобильном приложении Tapo:
#   Settings → Advanced Settings → Camera Account
# Это отдельные креды от cloud-аккаунта (email TP-Link).
# Используются для RTSP-потока и snapshot.
TAPO_RTSP_USER=automonitoring
TAPO_RTSP_PASS=your_camera_account_password

# Cloud-аккаунт TP-Link (email/пароль из приложения Tapo).
# Сейчас не используется: нужен будет, когда добавим прямую проверку
# microSD через KLAP API на :443. Оставлен в .env заранее.
TAPO_USER=your_email@example.com
TAPO_PASS=your_cloud_password

# ═══════════════════════════════════════════════
# Системные (v2)
# ═══════════════════════════════════════════════
# Путь к ffmpeg.exe — нужен для снимков iPanda RTSP и TP-Link Tapo.
FFMPEG_PATH=C:\Users\dsadmin\ffmpeg\ffmpeg-8.1.1-essentials_build\bin\ffmpeg.exe
# Сколько дней хранить YYYY-MM-DD папки в Bitrix24 Disk (старее — удаляются).
SNAPSHOT_RETENTION_DAYS=30

# ═══════════════════════════════════════════════
# Bitrix24 Disk (v2) — заливка снимков камер
# ═══════════════════════════════════════════════
# Inbound webhook вида https://your-portal.bitrix24.ru/rest/<id>/<token>/
BITRIX_WEBHOOK_URL=
# ID корневой папки Disk, куда складывать (структура AutoCamera/<группа>/<объект>/<YYYY-MM-DD>/).
# Узнать: node src/bitrix-disk.js init-folder
BITRIX_ROOT_FOLDER_ID=
BITRIX_STORAGE_ID=

# ═══════════════════════════════════════════════
# Тестовый режим (НЕ задавать на проде)
# ═══════════════════════════════════════════════
# При TEST_MODE=true письма уходят только на тестовые адреса (см. banner
# в логах при запуске), helpdesk отключается при пустом HELPDESK_TO.
# TEST_MODE=true
