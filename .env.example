# ═══════════════════════════════════════════════
# SMTP — отправка отчётов и уведомлений helpdesk
# ═══════════════════════════════════════════════
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@yandex.ru
SMTP_PASS=your_app_password

# Куда отправлять отчёт по группе "Европласт" (можно несколько через запятую)
REPORT_TO_EVROPLAST=evroplast@yourdomain.com,manager@yourdomain.com

# Куда отправлять отчёт по группе "Онлайн" (можно несколько через запятую)
REPORT_TO_ONLINE=online-client@yourdomain.com

# Fallback-адрес: используется, если не задан group-specific (REPORT_TO_*)
REPORT_TO=admin@yourdomain.com

# Куда отправлять письма helpdesk (несколько через запятую)
HELPDESK_TO=helpdesk@yourdomain.com

# ═══════════════════════════════════════════════
# TRASSIR Производство — SDK HTTP API
# ═══════════════════════════════════════════════
TRASSIR_USER=Admin
TRASSIR_PASS=your_password

# ═══════════════════════════════════════════════
# HiWatch Склад — ISAPI
# ═══════════════════════════════════════════════
HIWATCH_SKLAD_URL=http://10.0.120.30/doc/page/login.asp
HIWATCH_SKLAD_USER=EfremovOE
HIWATCH_SKLAD_PASS=your_password

# ═══════════════════════════════════════════════
# HiWatch Цех выдува — ISAPI
# ═══════════════════════════════════════════════
HIWATCH_VYDUV_URL=http://10.0.120.40/doc/page/login.asp
HIWATCH_VYDUV_USER=admin
HIWATCH_VYDUV_PASS=your_password

# ═══════════════════════════════════════════════
# Европласт Стройка — SMB-записи
# ═══════════════════════════════════════════════
STROYKA_SMB_USER=your_smb_user
STROYKA_SMB_PASS=your_smb_password

# ═══════════════════════════════════════════════
# BEWARD (удалённые) — SMB-записи
# ═══════════════════════════════════════════════
BEWARD_SMB_USER=your_smb_user
BEWARD_SMB_PASS=your_smb_password

# ═══════════════════════════════════════════════
# iVMS (Hikvision удалённые) — ISAPI per camera
# ═══════════════════════════════════════════════
IVMS_AERO_USER=admin
IVMS_AERO_PASS=your_password
IVMS_T2_USER=admin
IVMS_T2_PASS=your_password
IVMS_MEGAFON_USER=admin
IVMS_MEGAFON_PASS=your_password

# ═══════════════════════════════════════════════
# Ростелеком — портал lk-b2b.camera.rt.ru
# ═══════════════════════════════════════════════
RT_PORTAL_URL=https://lk-b2b.camera.rt.ru
RT_PORTAL_USER=your_login
RT_PORTAL_PASS=your_password

# ═══════════════════════════════════════════════
# v2: Yandex Disk — хранение скриншотов с камер
# ═══════════════════════════════════════════════
# OAuth-токен (https://oauth.yandex.ru/ → создать приложение
# с правами cloud_api:disk.read,write → выпустить токен).
# Если пусто — снимки не делаются и не льются.
YANDEX_DISK_TOKEN=
# Корневая папка на Я.Диске (создаётся автоматически)
YANDEX_DISK_ROOT=/AutoCamera
# Сколько дней хранить снимки до автоматической очистки
SNAPSHOT_RETENTION_DAYS=30
# Путь к ffmpeg (нужен для RTSP-снимков с iPanda).
# Если ffmpeg в PATH — оставьте просто "ffmpeg".
FFMPEG_PATH=ffmpeg

# ═══════════════════════════════════════════════
# v2: Тестовый режим (только для dev-окружения!)
# ═══════════════════════════════════════════════
# При TEST_MODE=true index.js печатает большой баннер при старте,
# подсвечивающий тестовые адреса получателей. Используется в
# C:\Users\dsadmin\Desktop\autocamera-v2 чтобы предотвратить
# случайную отправку клиентам.
TEST_MODE=false
