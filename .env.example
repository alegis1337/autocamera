# ═══════════════════════════════════════════════
# polza.ai API
# ═══════════════════════════════════════════════
POLZA_API_KEY=your_api_key_here
POLZA_MODEL=google/gemini-3.1-flash-lite-preview

# ═══════════════════════════════════════════════
# Камеры — Новый цех (iPanda, 10.0.120.220)
# ═══════════════════════════════════════════════
NOVIY_CEH_URL=http://10.0.120.220/
NOVIY_CEH_USER=admin
NOVIY_CEH_PASS=your_password_here

# ═══════════════════════════════════════════════
# Камеры — Склад (HiWatch, 10.0.120.30)
# ═══════════════════════════════════════════════
HIWATCH_SKLAD_URL=http://10.0.120.30/doc/page/login.asp
HIWATCH_SKLAD_USER=EfremovOE
HIWATCH_SKLAD_PASS=your_password_here

# ═══════════════════════════════════════════════
# SMTP Email
# ═══════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

REPORT_FROM=autocamera@yourdomain.com
REPORT_TO=admin@yourdomain.com
